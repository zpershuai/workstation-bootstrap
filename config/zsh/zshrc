# Interactive zsh config (managed by workstation-bootstrap).

# OpenSpec shell completions configuration
fpath=("${HOME}/.oh-my-zsh/custom/completions" $fpath)

export ZSH="${HOME}/.oh-my-zsh"
DISABLE_AUTO_UPDATE="true"
ZSH_THEME="ys"

plugins=(autojump macos)

append_omz_plugin_if_exists() {
  local plugin="$1"
  if [[ -d "${ZSH}/plugins/${plugin}" || -d "${ZSH_CUSTOM:-${ZSH}/custom}/plugins/${plugin}" ]]; then
    plugins+=("${plugin}")
  fi
}

append_omz_plugin_if_exists "adb"
append_omz_plugin_if_exists "zsh-autosuggestions"
append_omz_plugin_if_exists "zsh-syntax-highlighting"

if [[ -f "${ZSH}/oh-my-zsh.sh" ]]; then
  source "${ZSH}/oh-my-zsh.sh"
fi

# Fallback for zsh-autosuggestions when installed outside oh-my-zsh plugins.
if [[ ! " ${plugins[*]} " =~ " zsh-autosuggestions " ]]; then
  if command -v brew >/dev/null 2>&1; then
    _autosuggest_path="$(brew --prefix zsh-autosuggestions 2>/dev/null)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
    if [[ -f "${_autosuggest_path}" ]]; then
      source "${_autosuggest_path}"
    fi
    unset _autosuggest_path
  elif [[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
    source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
  fi
fi

# Keep login-shell logic in ~/.zprofile.
# Login shell will load ~/.zprofile automatically, so only source it in non-login shells.
if [[ ! -o login && -f "${HOME}/.zprofile" ]]; then
  source "${HOME}/.zprofile"
fi
